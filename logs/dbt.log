  create temporary table "kd_stamm__snapshot__dbt_tmp084731064353"
  
  
    as
  
  (
    
    
        
    
    with snapshot_query as (

        select * from "sdp__fva"."kd_stamm__inp"."kd_stamm__inp"

    ),

    snapshotted_data as (

        select *, 
    
        concat(userbk_nr, '|', kd_lnr) as dbt_unique_key
    

        from "sdp__fva"."kd_stamm__cor"."kd_stamm__snapshot"
        where
            
		
		

		
                ( (dbt_valid_to = to_timestamp('2299-12-31 00:00:00', 'YYYY-MM-DD HH24:MI:SS'))
 or dbt_valid_to is null )
            

    ),

    insertions_source_data as (

        select *, 
    
        concat(userbk_nr, '|', kd_lnr) as dbt_unique_key
    
,
            load_ts as dbt_updated_at,
            load_ts as dbt_valid_from,
            
  
  coalesce(nullif(load_ts, load_ts), to_timestamp('2299-12-31 00:00:00', 'YYYY-MM-DD HH24:MI:SS'))
  as dbt_valid_to
,
            md5(coalesce(cast(concat(userbk_nr, '|', kd_lnr) as varchar ), '')
         || '|' || coalesce(cast(load_ts as varchar ), '')
        ) as dbt_scd_id

        from snapshot_query
    ),

    updates_source_data as (

        select *, 
    
        concat(userbk_nr, '|', kd_lnr) as dbt_unique_key
    
,
            load_ts as dbt_updated_at,
            load_ts as dbt_valid_from,
            load_ts as dbt_valid_to

        from snapshot_query
    ),

    deletes_source_data as (

        select *, 
    
        concat(userbk_nr, '|', kd_lnr) as dbt_unique_key
    

        from snapshot_query
    ),
    

    insertions as (

        select
            'insert' as dbt_change_type,
            source_data.*,'False' as dbt_is_deleted

        from insertions_source_data as source_data
        left outer join snapshotted_data
            on 
    
        snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
    

            where 
    
        snapshotted_data.dbt_unique_key is null
    

            or (
    
        snapshotted_data.dbt_unique_key is not null
    
 and (
               (snapshotted_data.dbt_valid_from < source_data.load_ts)or snapshotted_data.dbt_is_deleted = 'True' 
            )

        )

    ),

    updates as (

        select
            'update' as dbt_change_type,
            source_data.*,
            snapshotted_data.dbt_scd_id, snapshotted_data.dbt_is_deleted

        from updates_source_data as source_data
        join snapshotted_data
            on 
    
        snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
    

        where (
            (snapshotted_data.dbt_valid_from < source_data.load_ts)or snapshotted_data.dbt_is_deleted = 'True' 
        )
    )
    ,
    deletes as (

        select
            'delete' as dbt_change_type,
            source_data.*,
            now()::timestamp without time zone as dbt_valid_from,
            now()::timestamp without time zone as dbt_updated_at,
            now()::timestamp without time zone as dbt_valid_to,
            snapshotted_data.dbt_scd_id, snapshotted_data.dbt_is_deleted
        from snapshotted_data
        left join deletes_source_data as source_data
            on 
    
        snapshotted_data.dbt_unique_key = source_data.dbt_unique_key
    

            where 
    
        source_data.dbt_unique_key is null
    

            and not (
                --avoid updating the record's valid_to if the latest entry is marked as deleted
                snapshotted_data.dbt_is_deleted = 'True'
                and
                snapshotted_data.dbt_valid_to = to_timestamp('2299-12-31 00:00:00', 'YYYY-MM-DD HH24:MI:SS')
            )
    )
        
        
    ,
